# Copy this file to `.env` and fill in real values. Never commit the real .env.

# MongoDB Atlas connection string.
# Get this from Atlas → Database → Connect → "Drivers" → copy the URI, then
# replace <password> with your DB user's password and add a database name
# at the end (e.g. /chickencenter) before the "?" query params.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/chickencenter?retryWrites=true&w=majority

# Any long random string — used to sign JWT tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# How long a login session (JWT) stays valid before needing to log in again.
JWT_EXPIRES_IN=30d

# Port the server listens on. Cloud hosts (Render/Railway) usually inject
# their own PORT env var automatically — this is just the local default.
PORT=5000

# Comma-separated list of frontend origins allowed to call this API
# (your deployed frontend URL, plus localhost for local dev).
CORS_ORIGIN=http://localhost:3000

# One-time setup key required to create the FIRST owner account via
# POST /api/auth/bootstrap-owner. Set this to something only you know, use it
# once to create your owner login, then you can delete/rotate it — after the
# first owner exists, that endpoint refuses to create another one anyway.
BOOTSTRAP_KEY=change_me_before_first_deploy
